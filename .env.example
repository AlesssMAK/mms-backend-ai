# Copy to `.env` and adjust as needed.

# --- App ---
PORT=3030
NODE_ENV=development

# Mongo (matches docker-compose.yml service "mongo")
MONGO_URL=mongodb://localhost:27017/mms

# --- Auth ---
JWT_SECRET=change-me-in-production
ADMIN_COOKIE_SECRET=change-me-in-production
ADMIN_SESSION_SECRET=change-me-in-production

# --- Sockets ---
SOCKET_CORS_ORIGIN=http://localhost:3000

# --- Cron (A5) ---
CRON_ENABLED=true

# --- Email (A6) ---
# stub  -> log only, no SMTP send (default)
# smtp  -> send via SMTP_* below (use MailPit in dev)
EMAIL_DRIVER=smtp
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
FRONTEND_URL=http://localhost:3000

# --- Cloudinary (uploads) ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
